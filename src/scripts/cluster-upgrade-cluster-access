#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Reconcile cluster access configuration to match cluster.yaml
#
# Syncs authentication mode, creates missing access entries, and
# removes entries not defined in cluster.yaml.
#
# If accessConfig is not defined in cluster.yaml, this is a no-op
# on the assumption that access is managed elsewhere (eg Terraform).
# If accessConfig is present but empty, also treated as managed elsewhere.
#
# Entry reconciliation requires authenticationMode to be API or
# API_AND_CONFIG_MAP. CONFIG_MAP mode does not use access entries.
#
# Usage: cluster upgrade cluster-access [--dry-run]
set -euo pipefail

dry_run=false
case "${1:-}" in
  --dry-run)
    dry_run=true
    shift
    ;;
  "")
    ;;
  *)
    echo "ERROR: Unknown flag '${1}'" >&2
    echo "Usage: cluster upgrade cluster-access [--dry-run]" >&2
    exit 1
    ;;
esac

CLUSTER_SCRIPT_DIR="${CLUSTER_SCRIPT_DIR:?CLUSTER_SCRIPT_DIR must be set}"
CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

has_access_config=$(yq '.accessConfig // ""' "${CLUSTER_CONFIG}")
if [[ -z "${has_access_config}" || "${has_access_config}" == "null" || "${has_access_config}" == "{}" ]]; then
  echo "Access config not defined in ${CLUSTER_CONFIG}, skipping (managed elsewhere)."
  exit 0
fi

# --- Authentication mode ---

auth_mode=$(yq '.accessConfig.authenticationMode // ""' "${CLUSTER_CONFIG}")
if [[ -n "${auth_mode}" && "${auth_mode}" != "null" ]]; then
  if [[ "${dry_run}" == "true" ]]; then
    echo "Dry run: would reconcile authentication mode to '${auth_mode}' for ${cluster_name}."
  else
    echo "Reconciling authentication mode for ${cluster_name}..."
    eksctl utils update-authentication-mode -f "${CLUSTER_CONFIG}"
  fi
  echo ""
else
  echo "Authentication mode not defined in ${CLUSTER_CONFIG}, skipping."
  echo ""
fi

# --- Access entries ---

if [[ "${auth_mode}" != "API" && "${auth_mode}" != "API_AND_CONFIG_MAP" ]]; then
  echo "Authentication mode is '${auth_mode:-not set}', access entry reconciliation requires API or API_AND_CONFIG_MAP."
  echo ""
  echo "Access config for ${cluster_name} reconciled to match ${CLUSTER_CONFIG}."
  exit 0
fi

has_entries=$(yq '.accessConfig.accessEntries // "" | length' "${CLUSTER_CONFIG}")
if [[ "${has_entries}" -eq 0 ]]; then
  echo "No access entries defined in ${CLUSTER_CONFIG}, skipping entry reconciliation."
  echo ""
  echo "Access config for ${cluster_name} reconciled to match ${CLUSTER_CONFIG}."
  exit 0
fi

if [[ "${dry_run}" == "true" ]]; then
  desired_arns=$(yq -r '.accessConfig.accessEntries[].principalARN' "${CLUSTER_CONFIG}" | sort)
  live_arns=$(eksctl get accessentry --cluster "${cluster_name}" -o yaml | yq -r '.[].principalARN' | sort)

  echo "Dry run: access entries for ${cluster_name}"
  echo ""
  echo "  Desired (from cluster.yaml):"
  while IFS= read -r arn; do
    echo "    ${arn}"
  done <<< "${desired_arns}"
  echo ""
  echo "  Live (on cluster):"
  if [[ -z "${live_arns}" ]]; then
    echo "    (none)"
  else
    while IFS= read -r arn; do
      echo "    ${arn}"
    done <<< "${live_arns}"
  fi
  echo ""

  missing=$(comm -23 <(echo "${desired_arns}") <(echo "${live_arns}"))
  if [[ -n "${missing}" ]]; then
    echo "  Would create:"
    while IFS= read -r arn; do
      echo "    ${arn}"
    done <<< "${missing}"
  else
    echo "  Nothing to create."
  fi

  extras=$(comm -13 <(echo "${desired_arns}") <(echo "${live_arns}"))
  if [[ -n "${extras}" ]]; then
    echo "  Would delete:"
    while IFS= read -r arn; do
      echo "    ${arn}"
    done <<< "${extras}"
  else
    echo "  Nothing to delete."
  fi

  echo ""
  echo "Dry run complete. No changes were made."
else
  echo "--- Creating missing access entries ---"
  "${CLUSTER_SCRIPT_DIR}/cluster-create-access-entries"
  echo ""

  echo "--- Removing extra access entries ---"
  "${CLUSTER_SCRIPT_DIR}/cluster-delete-access-entries"
  echo ""

  echo "Access config for ${cluster_name} reconciled to match ${CLUSTER_CONFIG}."
fi
