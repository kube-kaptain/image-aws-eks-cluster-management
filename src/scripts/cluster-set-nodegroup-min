# Set the minimum size of a nodegroup
#
# Usage: cluster set nodegroup-min <nodegroup-name> <value>
set -euo pipefail

if [[ $# -ne 2 ]]; then
  echo "Usage: cluster set nodegroup-min <nodegroup-name> <value>" >&2
  exit 1
fi

nodegroup_name="$1"
min_size="$2"

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

echo "Setting nodegroup ${nodegroup_name} minSize to ${min_size}..."
AWS_PAGER="" aws eks update-nodegroup-config \
  --cluster-name "${cluster_name}" \
  --nodegroup-name "${nodegroup_name}" \
  --scaling-config "minSize=${min_size}"
echo "Done."
