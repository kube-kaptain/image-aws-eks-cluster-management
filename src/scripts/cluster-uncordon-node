# Uncordon a single node to allow pods to be scheduled on it again
#
# Usage: cluster uncordon node <node-name>
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: cluster uncordon node <node-name>" >&2
  exit 1
fi

if [[ $# -gt 1 ]]; then
  echo "ERROR: Too many arguments" >&2
  echo "Usage: cluster uncordon node <node-name>" >&2
  exit 1
fi

node_name="$1"

echo "Uncordoning node ${node_name}..."
kubectl uncordon "${node_name}"
echo "Node ${node_name} uncordoned."
