#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Decrypt and set up AWS credentials from an age-encrypted file
#
# Looks for /kd/secrets/aws-credentials.age, decrypts it using decrypt-age,
# if it exists, otherwise asks for access key id and secret access key from
# the user and in both cases writes the result to ~/.aws/credentials
#
# Usage: cluster setup-credentials
set -euo pipefail

if [[ $# -ne 0 ]]; then
  echo "ERROR: This command takes no arguments" >&2
  echo "Usage: cluster setup-credentials" >&2
  exit 1
fi

# read_secret - Read hidden input showing * for each character with backspace support
#
# Args:
#   $1 - prompt text
#
# Sets in caller scope:
#   REPLY - the entered value
read_secret() {
  local prompt="$1"
  local value=""
  local char

  printf '%s' "${prompt}"
  while IFS= read -r -s -n1 char; do
    if [[ -z "${char}" ]]; then
      # Enter pressed
      break
    elif [[ "${char}" == $'\x7f' || "${char}" == $'\b' ]]; then
      # Backspace or delete
      if [[ -n "${value}" ]]; then
        value="${value%?}"
        printf '\b \b'
      fi
    else
      value+="${char}"
      printf '*'
    fi
  done
  echo ""
  REPLY="${value}"
}

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

age_file="/kd/secrets/aws-credentials.age"

mkdir -p ~/.aws

if [[ -f "${age_file}" ]]; then
  echo "Encrypted credentials found at ${age_file}, decrypting..."

  export MOUNT_BASE_PATH="/kd/work/"

  identity_dir="${MOUNT_BASE_PATH}/secret"
  identity_file="${identity_dir}/environmentPassphrase"

  mkdir -p "${identity_dir}"

  read_secret "Please supply age private key with prefix AGE-SECRET-KEY-: "
  age_key="${REPLY}"

  if [[ "${age_key}" != AGE-SECRET-KEY-* ]]; then
    echo "ERROR: Key does not start with AGE-SECRET-KEY- prefix" >&2
    exit 1
  fi

  echo "${age_key}" > "${identity_file}"
  chmod 600 "${identity_file}"
  trap 'rm -f "${identity_file}"' EXIT

  output_file="${MOUNT_BASE_PATH}/aws-credentials"

  decrypt-age "${age_file}" "${output_file}"

  cp "${output_file}" ~/.aws/credentials
  rm -f "${output_file}"
else
  echo "No encrypted credentials found, entering credentials manually..."
  echo ""

  read_secret "AWS Access Key ID: "
  aws_access_key_id="${REPLY}"
  read_secret "AWS Secret Access Key: "
  aws_secret_access_key="${REPLY}"

  if [[ -z "${aws_access_key_id}" || -z "${aws_secret_access_key}" ]]; then
    echo "ERROR: Both access key ID and secret access key are required" >&2
    exit 1
  fi

  cat > ~/.aws/credentials <<EOF
[default]
aws_access_key_id=${aws_access_key_id}
aws_secret_access_key=${aws_secret_access_key}
EOF
fi

chmod 600 ~/.aws/credentials

# Validate credentials file has expected structure
if [[ "$(head -n1 ~/.aws/credentials)" != "[default]" ]]; then
  echo "ERROR: ~/.aws/credentials first line must be [default] profile header" >&2
  exit 1
fi
if ! grep -q '^aws_access_key_id=' ~/.aws/credentials; then
  echo "ERROR: ~/.aws/credentials missing aws_access_key_id" >&2
  exit 1
fi
if ! grep -q '^aws_secret_access_key=' ~/.aws/credentials; then
  echo "ERROR: ~/.aws/credentials missing aws_secret_access_key" >&2
  exit 1
fi

# Set up region from cluster.yaml
region=$(yq '.metadata.region' "${CLUSTER_CONFIG}")
cat > ~/.aws/config <<EOF
[default]
region=${region}
EOF
chmod 600 ~/.aws/config
echo "AWS region set to ${region} in ~/.aws/config"

echo "AWS credentials set up at ~/.aws/credentials"

# Generate kubeconfig for the cluster
cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")
echo "Generating kubeconfig for cluster ${cluster_name}..."
AWS_PAGER="" aws eks update-kubeconfig --name "${cluster_name}"
echo "Kubeconfig configured for cluster ${cluster_name}"
