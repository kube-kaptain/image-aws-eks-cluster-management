#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Delete an EKS nodegroup
#
# Usage: cluster delete nodegroup <nodegroup-name> [--force]
set -euo pipefail

force=""
nodegroup_name=""
for arg in "$@"; do
  case "${arg}" in
    --force) force="--force" ;;
    --*)
      echo "ERROR: Unknown flag '${arg}'" >&2
      echo "Usage: cluster delete nodegroup <nodegroup-name> [--force]" >&2
      exit 1
      ;;
    *)
      if [[ -n "${nodegroup_name}" ]]; then
        echo "ERROR: Too many arguments" >&2
        echo "Usage: cluster delete nodegroup <nodegroup-name> [--force]" >&2
        exit 1
      fi
      nodegroup_name="${arg}"
      ;;
  esac
done

if [[ -z "${nodegroup_name}" ]]; then
  echo "Usage: cluster delete nodegroup <nodegroup-name> [--force]" >&2
  exit 1
fi

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

echo "Deleting nodegroup ${nodegroup_name} from cluster ${cluster_name}..."
# shellcheck disable=SC2086 # force must word-split when set, disappear when empty
eksctl delete nodegroup --cluster "${cluster_name}" --name "${nodegroup_name}" --wait ${force}
echo "Nodegroup ${nodegroup_name} deleted."
