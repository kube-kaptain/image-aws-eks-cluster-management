# List EKS insights for the cluster defined in cluster.yaml
#
# Usage: cluster list insights
set -euo pipefail

if [[ $# -ne 0 ]]; then
  echo "ERROR: This command takes no arguments" >&2
  echo "Usage: cluster list insights" >&2
  exit 1
fi

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

echo "EKS insights for ${cluster_name}:"
echo ""
aws eks list-insights --cluster-name "${cluster_name}"
echo ""
echo "For more detail run 'cluster describe insight <ID>' for each insight."
