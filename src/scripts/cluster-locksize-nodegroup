#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Lock the size of a nodegroup by setting min and max to the current node count
#
# Usage: cluster locksize nodegroup <nodegroup-name>
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: cluster locksize nodegroup <nodegroup-name>" >&2
  exit 1
fi

if [[ $# -gt 1 ]]; then
  echo "ERROR: Too many arguments" >&2
  echo "Usage: cluster locksize nodegroup <nodegroup-name>" >&2
  exit 1
fi

nodegroup_name="$1"

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

raw=$(eksctl get nodegroup --cluster "${cluster_name}" --name "${nodegroup_name}" -o yaml)

current_min=$(echo "${raw}" | yq '.[0].MinSize')
current_max=$(echo "${raw}" | yq '.[0].MaxSize')
current_desired=$(echo "${raw}" | yq '.[0].DesiredCapacity')

if [[ -z "${current_desired}" || "${current_desired}" == "null" ]]; then
  echo "ERROR: Could not determine current size of nodegroup ${nodegroup_name}" >&2
  exit 1
fi

# Save original values so they can be restored by cluster-unlocksize-nodegroup
save_dir="/kd/work/locksize/${nodegroup_name}"
mkdir -p "${save_dir}"
echo "${current_min}" > "${save_dir}/min"
echo "${current_max}" > "${save_dir}/max"
echo "${current_desired}" > "${save_dir}/desired"
echo "Saved original sizes to ${save_dir}/ (min=${current_min}, max=${current_max}, desired=${current_desired})"

echo "Locking nodegroup ${nodegroup_name} to ${current_desired} node(s) (min=${current_desired}, max=${current_desired})..."
eksctl scale nodegroup --cluster "${cluster_name}" --name "${nodegroup_name}" --nodes "${current_desired}" --nodes-min "${current_desired}" --nodes-max "${current_desired}"
echo "Nodegroup ${nodegroup_name} locked at ${current_desired} node(s)."
