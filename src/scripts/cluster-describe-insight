#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Describe a single EKS insight in detail
#
# Usage: cluster describe insight <id>
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: cluster describe insight <id>" >&2
  exit 1
fi

if [[ $# -gt 1 ]]; then
  echo "ERROR: Too many arguments" >&2
  echo "Usage: cluster describe insight <id>" >&2
  exit 1
fi

insight_id="$1"

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

AWS_PAGER="" aws eks describe-insight --cluster-name "${cluster_name}" --id "${insight_id}"
