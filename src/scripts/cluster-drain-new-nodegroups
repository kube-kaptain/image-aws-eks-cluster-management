#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Drain all nodes in nodegroups that are defined in cluster.yaml
# Useful for rollback scenarios where you need to migrate workloads
# back to old nodegroups
#
# Usage: cluster drain new-nodegroups [--force]
set -euo pipefail

CLUSTER_SCRIPT_DIR="${CLUSTER_SCRIPT_DIR:?CLUSTER_SCRIPT_DIR must be set}"

force=""
case "${1:-}" in
  --force)
    force="--force"
    shift
    ;;
  "")
    ;;
  *)
    echo "ERROR: Unknown flag '${1}'" >&2
    echo "Usage: cluster drain new-nodegroups [--force]" >&2
    exit 1
    ;;
esac

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

# Get nodegroup names defined in cluster.yaml
configured_nodegroups=$(yq '.managedNodeGroups[].name // .nodeGroups[].name' "${CLUSTER_CONFIG}")

# Get nodegroup names currently on the cluster
live_nodegroups=$(eksctl get nodegroups --cluster "${cluster_name}" -o yaml | yq '.[].Name')

new_count=0
for ng in ${live_nodegroups}; do
  if echo "${configured_nodegroups}" | grep -qx "${ng}"; then
    echo "New nodegroup found: ${ng}"
    "${CLUSTER_SCRIPT_DIR}/cluster-drain-nodegroup" "${ng}" ${force}
    new_count=$((new_count + 1))
    echo ""
  fi
done

if [[ ${new_count} -eq 0 ]]; then
  echo "No new nodegroups found."
else
  echo "Drained ${new_count} new nodegroup(s)."
fi
