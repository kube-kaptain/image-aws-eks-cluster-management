#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Delete all nodegroups that are defined in cluster.yaml
# Useful for rollback scenarios where you need to remove newly created
# nodegroups and revert to the previous set
#
# Shows which nodegroups will be deleted and requires confirmation
# unless --yes is passed. Bails if no nodegroups are configured to
# avoid accidentally removing all nodegroups from the cluster.
#
# Usage: cluster delete new-nodegroups [--yes]
set -euo pipefail

confirm=true
case "${1:-}" in
  --yes)
    confirm=false
    shift
    ;;
  "")
    ;;
  *)
    echo "ERROR: Unknown flag '${1}'" >&2
    echo "Usage: cluster delete new-nodegroups [--yes]" >&2
    exit 1
    ;;
esac

if [[ $# -ne 0 ]]; then
  echo "ERROR: This command takes no arguments" >&2
  echo "Usage: cluster delete new-nodegroups [--yes]" >&2
  exit 1
fi

CLUSTER_SCRIPT_DIR="${CLUSTER_SCRIPT_DIR:?CLUSTER_SCRIPT_DIR must be set}"

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

has_managed=$(yq '.managedNodeGroups // ""' "${CLUSTER_CONFIG}")
has_unmanaged=$(yq '.nodeGroups // ""' "${CLUSTER_CONFIG}")
if [[ ( -z "${has_managed}" || "${has_managed}" == "null" ) && ( -z "${has_unmanaged}" || "${has_unmanaged}" == "null" ) ]]; then
  echo "Neither type of nodegroup key found in ${CLUSTER_CONFIG}, cannot determine what to keep."
  echo "Skipping deletion to avoid removing all nodegroups."
  exit 0
fi

managed_count=$(yq '.managedNodeGroups // "" | length' "${CLUSTER_CONFIG}")
unmanaged_count=$(yq '.nodeGroups // "" | length' "${CLUSTER_CONFIG}")
if [[ "${managed_count}" -eq 0 && "${unmanaged_count}" -eq 0 ]]; then
  echo "No nodegroups defined in ${CLUSTER_CONFIG}, cannot determine what to keep."
  echo "Skipping deletion to avoid removing all nodegroups."
  exit 0
fi

# Get nodegroup names defined in cluster.yaml
configured_nodegroups=$(yq '.managedNodeGroups[].name // .nodeGroups[].name' "${CLUSTER_CONFIG}")

# Get nodegroup names currently on the cluster
live_nodegroups=$(eksctl get nodegroups --cluster "${cluster_name}" -o yaml | yq '.[].Name')

# Build list of nodegroups in cluster.yaml (new ones)
targets=()
for ng in ${live_nodegroups}; do
  if echo "${configured_nodegroups}" | grep -qx "${ng}"; then
    targets+=("${ng}")
  fi
done

if [[ ${#targets[@]} -eq 0 ]]; then
  echo "No new nodegroups found."
  exit 0
fi

if [[ "${confirm}" == "true" ]]; then
  echo "Will delete the following ${#targets[@]} new nodegroup(s) defined in cluster.yaml:"
  for ng in "${targets[@]}"; do
    echo "  ${ng}"
  done
  printf "Type 'yes' to proceed: "
  read -r answer
  if [[ "${answer}" != "yes" ]]; then
    echo "Aborted."
    exit 0
  fi
fi

for ng in "${targets[@]}"; do
  "${CLUSTER_SCRIPT_DIR}/cluster-delete-nodegroup" "${ng}"
done

echo "Deleted ${#targets[@]} new nodegroup(s)."
