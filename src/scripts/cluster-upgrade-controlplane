#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Upgrade the EKS control plane to match the version in cluster.yaml
#
# Usage: cluster upgrade controlplane [--dry-run]
set -euo pipefail

approve="--approve"
case "${1:-}" in
  --dry-run)
    approve=""
    shift
    ;;
  "")
    ;;
  *)
    echo "ERROR: Unknown flag '${1}'" >&2
    echo "Usage: cluster upgrade controlplane [--dry-run]" >&2
    exit 1
    ;;
esac

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

echo "Upgrading control plane for ${cluster_name}..."
eksctl upgrade cluster -f "${CLUSTER_CONFIG}" ${approve}

echo ""
if [[ -z "${approve}" ]]; then
  echo "Dry run complete. No changes were made."
else
  echo "Control plane for ${cluster_name} upgraded successfully."
fi
