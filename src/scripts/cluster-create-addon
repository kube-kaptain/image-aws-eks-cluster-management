#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Create a single EKS addon from cluster.yaml
#
# Usage: cluster create addon <addon-name> [--force]
set -euo pipefail

force=""
args=()
for arg in "$@"; do
  case "${arg}" in
    --force)
      force="--force"
      ;;
    --*)
      echo "ERROR: Unknown flag '${arg}'" >&2
      echo "Usage: cluster create addon <addon-name> [--force]" >&2
      exit 1
      ;;
    *)
      args+=("${arg}")
      ;;
  esac
done

if [[ ${#args[@]} -lt 1 ]]; then
  echo "Usage: cluster create addon <addon-name> [--force]" >&2
  exit 1
fi

if [[ ${#args[@]} -gt 1 ]]; then
  echo "ERROR: Too many arguments" >&2
  echo "Usage: cluster create addon <addon-name> [--force]" >&2
  exit 1
fi

addon_name="${args[0]}"

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

echo "Creating addon ${addon_name} on cluster ${cluster_name}..."
# shellcheck disable=SC2086 # force must word-split when set, disappear when empty
eksctl create addon -f "${CLUSTER_CONFIG}" --name "${addon_name}" ${force}
echo "Addon ${addon_name} created successfully."
