#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Drain a single node, evicting all pods and preventing new scheduling
#
# Usage: cluster drain node <node-name> [--force]
set -euo pipefail

force=""
args=()
for arg in "$@"; do
  case "${arg}" in
    --force)
      force="--force"
      ;;
    --*)
      echo "ERROR: Unknown flag '${arg}'" >&2
      echo "Usage: cluster drain node <node-name> [--force]" >&2
      exit 1
      ;;
    *)
      args+=("${arg}")
      ;;
  esac
done

if [[ ${#args[@]} -lt 1 ]]; then
  echo "Usage: cluster drain node <node-name> [--force]" >&2
  exit 1
fi

if [[ ${#args[@]} -gt 1 ]]; then
  echo "ERROR: Too many arguments" >&2
  echo "Usage: cluster drain node <node-name> [--force]" >&2
  exit 1
fi

node_name="${args[0]}"

echo "Draining node ${node_name}..."
kubectl drain "${node_name}" --ignore-daemonsets --delete-emptydir-data ${force}
echo "Node ${node_name} drained."
