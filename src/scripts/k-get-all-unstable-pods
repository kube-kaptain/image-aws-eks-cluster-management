#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# List pods that are not in a healthy steady state across all namespaces
#
# Uses structured YAML output from kubectl to avoid parsing human-readable
# table formats. Extracts one line per pod via yq, then filters in bash.
# Output emulates the familiar kubectl get pods format.
#
# Shows pods matching any of:
#   - Phase is not Running, Succeeded, or Completed
#   - Not all containers are ready
#   - Non-zero restart count
#
# Usage: k-get-all-unstable-pods
set -euo pipefail

if [[ $# -ne 0 ]]; then
  echo "ERROR: This command takes no arguments" >&2
  echo "Usage: k-get-all-unstable-pods" >&2
  exit 1
fi

# Format seconds into kubectl-style age string (eg 5d, 3h12m, 42s)
format_age() {
  local seconds="$1"
  local days=$((seconds / 86400))
  local hours=$(( (seconds % 86400) / 3600 ))
  local minutes=$(( (seconds % 3600) / 60 ))

  if [[ ${days} -gt 0 ]]; then
    echo "${days}d"
  elif [[ ${hours} -gt 0 ]]; then
    echo "${hours}h${minutes}m"
  elif [[ ${minutes} -gt 0 ]]; then
    echo "${minutes}m"
  else
    echo "${seconds}s"
  fi
}

now=$(date +%s)

# Single yq call: extract one line per pod with all fields needed for filtering
# Fields: namespace, name, phase, ready_count, total_count, restarts, status_reason, age_timestamp
# shellcheck disable=SC2016 # single quotes are intentional, this is a yq expression not shell
pod_data=$(kubectl get pods --all-namespaces -o yaml | yq -r '
  .items[] |
  [
    .metadata.namespace,                                                       # NAMESPACE column
    .metadata.name,                                                            # NAME column
    .status.phase,                                                             # Used for filtering (Running/Succeeded/Pending/Failed)
    (.status.containerStatuses // [] | map(select(.ready == true)) | length),  # READY numerator (eg the 1 in 1/2)
    (.status.containerStatuses // [] | length),                                # READY denominator (eg the 2 in 1/2)
    (.status.containerStatuses // [] | map(.restartCount) | .[] as $x ireduce(0; . + $x)),  # RESTARTS column (sum across all containers)
    ((.status.containerStatuses // [])[] | .state | to_entries[0] | select(.value.reason != null) | .value.reason) // .status.phase,  # STATUS column (CrashLoopBackOff etc, or phase as fallback)
    .metadata.creationTimestamp                                                # AGE column (converted to duration in bash)
  ] | @tsv')

if [[ -z "${pod_data}" ]]; then
  echo "No pods found."
  exit 0
fi

header_printed=false
found=0
while IFS=$'\t' read -r namespace name phase ready_count total_count restarts status_reason age_timestamp; do
  # Skip pods in a healthy terminal state
  if [[ "${phase}" == "Succeeded" ]]; then
    continue
  fi

  unstable=false

  # Not running
  if [[ "${phase}" != "Running" ]]; then
    unstable=true
  fi

  # Not all containers ready
  if [[ "${ready_count}" -ne "${total_count}" ]]; then
    unstable=true
  fi

  # Non-zero restarts
  if [[ "${restarts}" -gt 0 ]]; then
    unstable=true
  fi

  if [[ "${unstable}" != "true" ]]; then
    continue
  fi

  if [[ "${header_printed}" != "true" ]]; then
    printf "%-20s %-50s %-8s %-20s %8s   %s\n" "NAMESPACE" "NAME" "READY" "STATUS" "RESTARTS" "AGE"
    header_printed=true
  fi

  ready_display="${ready_count}/${total_count}"
  created=$(date -d "${age_timestamp}" +%s)
  age=$(format_age $((now - created)))
  printf "%-20s %-50s %-8s %-20s %8s   %s\n" "${namespace}" "${name}" "${ready_display}" "${status_reason}" "${restarts}" "${age}"
  found=$((found + 1))
done <<< "${pod_data}"

if [[ ${found} -eq 0 ]]; then
  echo "No unstable pods found."
else
  echo ""
  echo "${found} unstable pod(s) found."
fi
