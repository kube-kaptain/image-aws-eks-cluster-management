# List pods that are not in a healthy steady state across all namespaces
#
# Usage: cluster list all-unstable-pods
set -euo pipefail

if [[ $# -ne 0 ]]; then
  echo "ERROR: This command takes no arguments" >&2
  echo "Usage: cluster list all-unstable-pods" >&2
  exit 1
fi

CLUSTER_SCRIPT_DIR="${CLUSTER_SCRIPT_DIR:?CLUSTER_SCRIPT_DIR must be set}"

exec "${CLUSTER_SCRIPT_DIR}/k-get-all-unstable-pods"
