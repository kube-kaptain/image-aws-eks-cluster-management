#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Automated nodegroup rollover - fast path
#
# Creates new nodegroups, drains and deletes old ones. Skips control plane
# and addon upgrades. Use this when the control plane and addons are already
# up-to-date and you only need to roll the nodegroups.
#
# Only use this if your workloads are resilient (multiple replicas, PDBs,
# all three probes, termination grace period, graceful shutdown, and more).
# Singletons and fragile misconfigured workloads will experience downtime.
#
# Usage: cluster upgrade fast-nodegroups-only-automatic
set -euo pipefail

if [[ $# -ne 0 ]]; then
  echo "ERROR: This command takes no arguments" >&2
  echo "Usage: cluster upgrade fast-nodegroups-only-automatic" >&2
  exit 1
fi

CLUSTER_SCRIPT_DIR="${CLUSTER_SCRIPT_DIR:?CLUSTER_SCRIPT_DIR must be set}"
CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")
configured_version=$(yq '.metadata.version' "${CLUSTER_CONFIG}")

print_banner() {
  local title="$1"
  local inner_width=74
  local text_len=${#title}
  local pad_left=$(( (inner_width - text_len) / 2 ))
  local pad_right=$(( inner_width - text_len - pad_left ))

  echo ""
  echo ""
  echo "################################################################################"
  printf "###%74s###\n" ""
  printf "###%*s%s%*s###\n" "${pad_left}" "" "${title}" "${pad_right}" ""
  printf "###%74s###\n" ""
  echo "################################################################################"
  echo ""
}

print_banner "Step 1: Validating requirements"
"${CLUSTER_SCRIPT_DIR}/cluster-validate-image"
echo ""
echo "Checking AWS identity..."
AWS_PAGER="" aws sts get-caller-identity
echo ""
echo "Checking Kubernetes access..."
if kubectl get ns > /dev/null 2>&1; then
  echo "Okay."
else
  echo "Fail."
  exit 1
fi

print_banner "Step 2: EKS Insights"
mkdir -p /kd/work/cluster-upgrade-fast-nodegroups-only-automatic
"${CLUSTER_SCRIPT_DIR}/cluster-list-insights" | tee /kd/work/cluster-upgrade-fast-nodegroups-only-automatic/insights-before

print_banner "Step 3: Confirmation"
echo "Cluster: ${cluster_name}"
echo ""
echo "This will create new nodegroups for ${configured_version}, drain all workloads"
echo "from old nodegroups, and delete the old nodegroups."
echo ""
echo "Control plane and addons will NOT be touched."
echo ""
echo "To confirm, type the Kubernetes version you're expecting the nodegroups to match:"
read -r entered_version

if [[ "${entered_version}" != "${configured_version}" ]]; then
  echo "ERROR: '${entered_version}' does not match target version '${configured_version}'" >&2
  exit 1
fi

print_banner "Step 4: Capturing before state"
"${CLUSTER_SCRIPT_DIR}/cluster-list-all" | tee /kd/work/cluster-upgrade-fast-nodegroups-only-automatic/before

print_banner "Step 5: Creating new nodegroups for ${configured_version}"
"${CLUSTER_SCRIPT_DIR}/cluster-create-nodegroups"

print_banner "Step 6: Locking old nodegroup sizes"
"${CLUSTER_SCRIPT_DIR}/cluster-locksize-old-nodegroups"

print_banner "Step 7: Cordoning old nodegroups"
"${CLUSTER_SCRIPT_DIR}/cluster-cordon-old-nodegroups"

print_banner "Step 8: Draining old nodegroups"
"${CLUSTER_SCRIPT_DIR}/cluster-drain-old-nodegroups"

print_banner "Step 9: Deleting old nodegroups"
"${CLUSTER_SCRIPT_DIR}/cluster-delete-old-nodegroups" --yes

print_banner "Step 10: Capturing after state"
"${CLUSTER_SCRIPT_DIR}/cluster-list-all" | tee /kd/work/cluster-upgrade-fast-nodegroups-only-automatic/after

print_banner "Step 11: Automated nodegroup rollover complete"
echo "Before and after state captured in /kd/work/cluster-upgrade-fast-nodegroups-only-automatic/"
echo ""
echo "Next: upgrade other components within the cluster to match."
