#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Create all EKS addons defined in cluster.yaml in parallel
#
# Each addon is created as a background process to avoid waiting for
# CloudFormation stacks sequentially. Waits for all to complete and
# reports success or failure for each.
#
# Usage: cluster create addons [--force]
set -euo pipefail

force=""
case "${1:-}" in
  --force)
    force="--force"
    shift
    ;;
  "")
    ;;
  *)
    echo "ERROR: Unknown flag '${1}'" >&2
    echo "Usage: cluster create addons [--force]" >&2
    exit 1
    ;;
esac

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

addon_names=$(yq '.addons[].name' "${CLUSTER_CONFIG}")

if [[ -z "${addon_names}" ]]; then
  echo "No addons defined in ${CLUSTER_CONFIG}."
  exit 0
fi

pids=()
names=()
for addon in ${addon_names}; do
  echo "Creating addon: ${addon}"
  # shellcheck disable=SC2086 # force must word-split when set, disappear when empty
  eksctl create addon -f "${CLUSTER_CONFIG}" --name "${addon}" ${force} &
  pids+=($!)
  names+=("${addon}")
done

echo ""
echo "Waiting for ${#pids[@]} addon(s) to finish creating..."

failed=0
for i in "${!pids[@]}"; do
  if wait "${pids[${i}]}"; then
    echo "  ${names[${i}]}: done"
  else
    echo "  ${names[${i}]}: FAILED"
    failed=$((failed + 1))
  fi
done

if [[ ${failed} -gt 0 ]]; then
  echo ""
  echo "ERROR: ${failed} addon(s) failed to create." >&2
  exit 1
fi

echo ""
echo "All ${#names[@]} addon(s) created successfully."
