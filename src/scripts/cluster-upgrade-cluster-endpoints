#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Reconcile cluster endpoint access configuration to match cluster.yaml
#
# Updates vpc.clusterEndpoints and vpc.publicAccessCIDRs to match the config.
#
# Usage: cluster upgrade cluster-endpoints [--dry-run]
set -euo pipefail

approve="--approve"
case "${1:-}" in
  --dry-run)
    approve=""
    shift
    ;;
  "")
    ;;
  *)
    echo "ERROR: Unknown flag '${1}'" >&2
    echo "Usage: cluster upgrade cluster-endpoints [--dry-run]" >&2
    exit 1
    ;;
esac

CLUSTER_CONFIG="${CLUSTER_CONFIG:?CLUSTER_CONFIG must be set}"

if [[ ! -f "${CLUSTER_CONFIG}" ]]; then
  echo "ERROR: ${CLUSTER_CONFIG} not found" >&2
  exit 1
fi

cluster_name=$(yq '.metadata.name' "${CLUSTER_CONFIG}")

echo "Reconciling cluster endpoint access for ${cluster_name}..."
eksctl utils update-cluster-vpc-config -f "${CLUSTER_CONFIG}" ${approve}

echo ""
if [[ -z "${approve}" ]]; then
  echo "Dry run complete. No changes were made."
else
  echo "Cluster endpoint access for ${cluster_name} reconciled to match ${CLUSTER_CONFIG}."
fi
