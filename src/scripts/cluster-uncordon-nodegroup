#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Uncordon all nodes in a nodegroup
#
# Usage: cluster uncordon nodegroup <nodegroup-name> [--dry-run]
set -euo pipefail

dry_run=false
nodegroup_name=""
for arg in "$@"; do
  case "${arg}" in
    --dry-run) dry_run=true ;;
    --*)
      echo "ERROR: Unknown flag '${arg}'" >&2
      echo "Usage: cluster uncordon nodegroup <nodegroup-name> [--dry-run]" >&2
      exit 1
      ;;
    *)
      if [[ -n "${nodegroup_name}" ]]; then
        echo "ERROR: Too many arguments" >&2
        echo "Usage: cluster uncordon nodegroup <nodegroup-name> [--dry-run]" >&2
        exit 1
      fi
      nodegroup_name="${arg}"
      ;;
  esac
done

if [[ -z "${nodegroup_name}" ]]; then
  echo "Usage: cluster uncordon nodegroup <nodegroup-name> [--dry-run]" >&2
  exit 1
fi

nodes=$(kubectl get nodes -l "eks.amazonaws.com/nodegroup=${nodegroup_name}" -o jsonpath='{.items[*].metadata.name}')

if [[ -z "${nodes}" ]]; then
  echo "No nodes found in nodegroup ${nodegroup_name}"
  exit 0
fi

if [[ "${dry_run}" == "true" ]]; then
  echo "Would uncordon the following nodes in nodegroup ${nodegroup_name}:"
  for node in ${nodes}; do
    echo "  ${node}"
  done
else
  echo "Uncordoning all nodes in nodegroup ${nodegroup_name}..."
  for node in ${nodes}; do
    echo "  Uncordoning ${node}..."
    kubectl uncordon "${node}"
  done
  echo "All nodes in nodegroup ${nodegroup_name} uncordoned."
fi
